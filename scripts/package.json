{
  "name": "notreda-me-scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.16.0"
  },
  "dependencies": {
    "@sentry/node": "10.53.1",
    "chalk": "5.6.2",
    "cheerio": "1.2.0",
    "date-fns": "4.3.0",
    "dotenv": "17.4.2",
    "lodash": "4.18.1",
    "puppeteer": "24.39.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.1",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
  },
  "scripts": {
    "lint": "prettier --check '**/*.{js,ts,json}' && echo 'Running ESLint...' && eslint . --report-unused-disable-directives --max-warnings 0 && echo 'All files pass linting!' && echo 'Running tsc...' && tsc --noEmit && echo 'All files pass type checking!'",
    "format": "prettier --write '**/*.{js,ts,json}'",
    "build": "tsc",
    "update-deps": "npx npm-check-updates -u --reject 'puppeteer' && npm install"
  }
}
